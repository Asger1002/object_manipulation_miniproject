<!-- Custom scene matching the coordinate frame of the grasp_preshaping Rust script.
     Coordinate frame rationale (all values in metres):
       - World origin (0,0,0) = centre of the target sphere, matching sphere.xyz scaled by 0.03.
       - Hand palm_r at (0, -0.11, -0.05) with identity orientation, matching:
             base_transform[(1,3)] = -0.11
             base_transform[(2,3)] = -0.05
             base_transform rotation = identity
         in grasp_preshaping/src/main.rs.
       - Sphere radius = 0.03 m = unit sphere.xyz points × default pointcloud_scale (0.03).
     The hand model is defined in mia_hand_right_grasp_frame.xml (same file as
     mia_hand_right.xml, only palm_r pos/quat changed). -->
<mujoco model="mia_hand_right custom scene">
  <include file="mia_hand_right_grasp_frame.xml"/>

  <!-- Camera framing: centre between sphere (0,0,0) and hand base (0,-0.11,-0.05) -->
  <statistic extent="0.4" center="0 -0.05 0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
      width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
      texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1" dir="0 0 -1" directional="true"/>
    <!-- Floor lowered to z=-0.1 so the hand body (z ~ -0.074 to -0.05) sits above it -->
    <geom name="floor" size="0 0 .125" type="plane" material="groundplane"
      pos="0 0 -0.1" conaffinity="15" condim="3"/>
    <!-- Origin marker: red sphere at world origin (0,0,0).
         Radius = 0.03 m = sphere.xyz unit radius × pointcloud_scale (0.03).
         This is the target object the hand is configured to grasp. -->
    <geom name="origin_marker" type="sphere" pos="0 0 0" size="0.03"
      rgba="1 0 0 1" contype="0" conaffinity="0"/>
  </worldbody>
</mujoco>
